# Get a free Google Places API key at https://console.cloud.google.com
# Enable: Maps JavaScript API + Places API
# The $200/month free credit covers thousands of searches — more than enough for personal use.
VITE_GOOGLE_PLACES_KEY=your_google_places_api_key

# Optional — for hosting online with Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
